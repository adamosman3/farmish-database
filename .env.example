# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# Postgres connection string (SSL required)
POSTGRES_URL=postgres://user:password@host:5432/dbname

# Amplitude Analytics API credentials
AMPLITUDE_API_KEY=your_amplitude_api_key
AMPLITUDE_SECRET_KEY=your_amplitude_secret_key

# HubSpot private app access token
HUBSPOT_TOKEN=your_hubspot_private_app_token

# Farmish OAuth2 (Doorkeeper) — register this app at <farmish>/oauth/applications
# with redirect URI <APP_URL>/api/auth/callback and scope "public".
FARMISH_URL=http://localhost:3000
FARMISH_CLIENT_ID=your_doorkeeper_application_uid
FARMISH_CLIENT_SECRET=your_doorkeeper_application_secret

# This app's own base URL. In dev, run on 3001 (`npm run dev -- -p 3001`)
# so it doesn't clash with Farmish on 3000.
APP_URL=http://localhost:3001

# Session cookie encryption key: at least 32 chars (openssl rand -hex 32)
SESSION_SECRET=generate_a_random_string_of_at_least_32_chars
